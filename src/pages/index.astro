  <script>
    // Navbar: entrada suave al cargar
    const navbar = document.getElementById("navbar")!;
    navbar.style.opacity = "0";
    navbar.style.transform = "translateY(-12px)";
    requestAnimationFrame(() => {
      navbar.style.transition = "opacity 0.4s ease, transform 0.4s ease";
      navbar.style.opacity = "1";
      navbar.style.transform = "translateY(0)";
    });

    // Hamburger menu
    const menuBtn = document.getElementById("menu-btn")!;
    const mobileMenu = document.getElementById("mobile-menu")!;
    const hamburgerLines = menuBtn.querySelectorAll(".hamburger-line");
    let menuOpen = false;

    function openMenu() {
      menuOpen = true;
      mobileMenu.classList.remove("max-h-0", "opacity-0");
      mobileMenu.classList.add("max-h-96", "opacity-100", "py-4");
      (hamburgerLines[0] as HTMLElement).style.transform = "translateY(8px) rotate(45deg)";
      (hamburgerLines[1] as HTMLElement).style.opacity = "0";
      (hamburgerLines[2] as HTMLElement).style.transform = "translateY(-8px) rotate(-45deg)";
    }

    function closeMenu() {
      menuOpen = false;
      mobileMenu.classList.add("max-h-0", "opacity-0");
      mobileMenu.classList.remove("max-h-96", "opacity-100", "py-4");
      (hamburgerLines[0] as HTMLElement).style.transform = "";
      (hamburgerLines[1] as HTMLElement).style.opacity = "";
      (hamburgerLines[2] as HTMLElement).style.transform = "";
    }

    menuBtn.addEventListener("click", () => {
      menuOpen ? closeMenu() : openMenu();
    });

    // Close mobile menu on link click
    document.querySelectorAll(".mobile-nav-link").forEach((link) => {
      link.addEventListener("click", () => closeMenu());
    });

    // Country selector
    const btn = document.getElementById("country-btn")!;
    const dropdown = document.getElementById("country-dropdown")!;
    const flagEl = document.getElementById("country-flag")!;

    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      dropdown.classList.toggle("hidden");
    });

    const priceCurrency = document.getElementById("price-currency")!;
    const priceAmount = document.getElementById("price-amount")!;
    const priceExtra = document.getElementById("price-extra")!;

    function updatePrice(code: string) {
      if (code === "ar") {
        priceCurrency.textContent = "ARS";
        priceAmount.textContent = "15.000";
        priceExtra.textContent = "+ ARS 6.500 por profesional adicional";
      } else {
        priceCurrency.textContent = "USD";
        priceAmount.textContent = "12";
        priceExtra.textContent = "+ USD 5 por profesional adicional";
      }
    }

    // Precio inicial según país por defecto (AR)
    updatePrice("ar");

    document.querySelectorAll(".country-option").forEach((opt) => {
      opt.addEventListener("click", () => {
        const code = (opt as HTMLElement).dataset.code!;
        (flagEl as HTMLImageElement).src = `https://flagcdn.com/20x15/${code}.png`;
        (flagEl as HTMLImageElement).alt = code.toUpperCase();
        dropdown.classList.add("hidden");
        updatePrice(code);
      });
    });

    document.addEventListener("click", () => dropdown.classList.add("hidden"));

    // Screenshot tabs
    const screenTabs = document.querySelectorAll(".screen-tab");
    const screenImages = ["agenda", "dashboard", "metricas"];

    screenTabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const screen = (tab as HTMLElement).dataset.screen!;

        screenTabs.forEach((t) => {
          t.classList.remove("bg-teal-600", "text-white");
          t.classList.add("bg-white/10", "text-slate-300");
        });
        tab.classList.add("bg-teal-600", "text-white");
        tab.classList.remove("bg-white/10", "text-slate-300");

        screenImages.forEach((s) => {
          const el = document.getElementById(`screen-${s}`)!;
          el.classList.add("hidden");
          el.classList.remove("block");
        });
        const target = document.getElementById(`screen-${screen}`)!;
        target.classList.remove("hidden");
        target.classList.add("block");
      });
    });

    // FAQ smooth open
    document.querySelectorAll("details").forEach((details) => {
      const summary = details.querySelector("summary")!;
      const body = details.querySelector(".faq-body") as HTMLElement;

      summary.addEventListener("click", (e) => {
        e.preventDefault();

        if (details.open) {
          const anim = body.animate(
            [{ height: body.scrollHeight + "px" }, { height: "0px" }],
            { duration: 280, easing: "ease-in-out" }
          );
          anim.onfinish = () => details.removeAttribute("open");
        } else {
          details.setAttribute("open", "");
          body.animate(
            [{ height: "0px" }, { height: body.scrollHeight + "px" }],
            { duration: 280, easing: "ease-in-out" }
          );
        }
      });
    });
  </script>
</Layout>
